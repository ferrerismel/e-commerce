# ==========================================
# D'XILVA STORE - ENVIRONMENT VARIABLES
# ==========================================
# Copia este archivo a .env.local y reemplaza los valores

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# QvaPay Configuration
QVAPAY_APP_ID=your-qvapay-app-id
QVAPAY_SECRET_KEY=your-qvapay-secret-key
QVAPAY_WEBHOOK_SECRET=your-qvapay-webhook-secret

# Stripe Configuration (optional)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Transfermóvil / Enzona Configuration
TRANSFERMOVIL_API_KEY=your-transfermovil-api-key
ENZONA_CLIENT_ID=your-enzona-client-id
ENZONA_CLIENT_SECRET=your-enzona-client-secret

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CURRENCY=USD
NEXT_PUBLIC_STORE_NAME="D'XILVA Store"

# Email Configuration (for transactional emails)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@dxilvastore.com

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
